generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 1. EL CLIENTE (Dueño de la invitación)
model User {
  id          String   @id @default(cuid())
  nombre      String
  email       String   @unique
  password    String
  role        String   @default("USER") // "ADMIN" o "USER"
  
  // Datos para la URL y Diseño
  slug        String   @unique // Ej: "boda-mario-y-clara"
  templateId  String   @default("DEMO1") // "DEMO1", "DEMO2", "DEMO3"

  songSuggestions SongSuggestion[]
  // RELACIONES
  // Un usuario tiene una única configuración de su evento
  eventConfig EventConfig? 
  // Un usuario tiene muchos invitados en su lista
  guests      Guest[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("users")
}

// 2. CONFIGURACIÓN DEL EVENTO (Lo que el cliente edita)
// Actualización del modelo EventConfig
model EventConfig {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // --- Multimedia ---
  heroImage        String?  @default("")
  videoUrl         String?  @default("")
  musicUrl         String?  @default("")
  carruselImages   String?  @default("[]") // Cloudinary URLs en JSON

  // --- Datos Principales ---
  eventName        String   @default("Mi Evento") // "Flor & Santi" o "Mis 15 - Olivia"
  eventDate        String   @default("2026-12-19")
  eventTime        String   @default("21:00")
  
  // --- Ubicaciones (Separadas para Bodas) ---
  // Salon / Fiesta
  venueName        String   @default("Nombre del Salón")
  venueAddress     String   @default("Calle Falsa 123")
  mapLink          String   @default("")
  
  // Iglesia / Ceremonia (Específico para Bodas)
// Iglesia / Ceremonia (Específico para Bodas)
  churchName       String?  @default("")
  churchAddress    String?  @default("")
  churchMapLink    String?  @default("")
  churchDate       String?  @default("") // <--- AGREGAR ESTO
  churchTime       String?  @default("") // <--- AGREGAR ESTO

  // --- Detalles ---
  dressCode        String   @default("Elegante Sport")
  dressDescription String   @default("¡Tu presencia es lo más importante!")
  
  // --- Regalos / CBU ---
  cbu              String   @default("")
  alias            String   @default("")
  bankName         String   @default("")
  holderName       String   @default("")

  // --- Relaciones Dinámicas ---
  itinerary        ItineraryItem[]
  witnesses        Witness[]

  updatedAt        DateTime @updatedAt
  @@map("event_config")
}

// 4. ITINERARIO (Los 8 puntos que mencionaste)
model ItineraryItem {
  id            String      @id @default(cuid())
  time          String      // "21:00hs"
  title         String      // "Recepción"
  description   String?     // Opcional
  icon          String      @default("Heart") // Nombre del icono de Lucide
  order         Int         // Para ordenar del 1 al 8
  
  eventConfigId String
  eventConfig   EventConfig @relation(fields: [eventConfigId], references: [id], onDelete: Cascade)

  @@map("itinerary_items")
}

// 5. TESTIGOS / PADRINOS (Los 4 de las bodas)
model Witness {
  id            String      @id @default(cuid())
  nombre        String
  rol           String      // "Testigo del Novio", "Madrina", etc.
  imageUrl      String?     // Foto de Cloudinary
  
  eventConfigId String
  eventConfig   EventConfig @relation(fields: [eventConfigId], references: [id], onDelete: Cascade)

  @@map("witnesses")
}

// 3. LOS INVITADOS (Los que confirman asistencia)
model Guest {
  id        String   @id @default(cuid())
  apellido  String
  cupos     Int      @default(1)
  codigo    String   @unique // Código para que el invitado entre a SU invitación
  status    String   @default("PENDING") // "CONFIRMED", "CANCELLED", "PENDING"
  dietary   String?  // Celíaco, Vegano, etc.
  
  // Relación: Cada invitado pertenece a un Usuario (Evento) específico
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("guests")
}

// Agrega esto al final de tu archivo schema.prisma
model SongSuggestion {
  id         String   @id @default(cuid())
  tema1      String?
  tema2      String?
  tema3      String?
  guestName  String?  // <--- AGREGAR ESTO PARA SABER QUIÉN SUGIRIÓ
  
  // Relación con el usuario (dueño de la fiesta)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}
