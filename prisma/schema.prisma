generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 1. ENUM DE PLANES (Nuevo)
enum PlanLevel {
  CLASSIC
  PREMIUM
  DELUXE
}

// 2. EL CLIENTE (Dueño de la invitación)
model User {
  id              String   @id @default(cuid())
  nombre          String
  email           String   @unique
  password        String
  role            String   @default("USER") 
  
  // Nivel de plan para habilitar/deshabilitar secciones
  planLevel       PlanLevel @default(CLASSIC) 
  
  slug            String   @unique 
  templateId      String   @default("")

  eventConfig     EventConfig? 
  guests          Guest[]
  songSuggestions SongSuggestion[]
  orders          Order[] 

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("users")
}

// 3. MODELO DE ÓRDENES Y PAGOS
enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
}

model Order {
  id                String        @id @default(cuid())
  userId            String?        
  user              User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  planName          String        // CLASSIC, PREMIUM, DELUXE
  amount            Float
  status            PaymentStatus @default(PENDING)
  
  mpPreferenceId    String?       @unique 
  mpPaymentId       String?       @unique 
  
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@map("orders")
}

// 4. CONFIGURACIÓN DEL EVENTO
model EventConfig {
  id                String          @id @default(cuid())
  userId            String          @unique
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  // --- Multimedia ---
  heroImage        String?          @default("")
  videoUrl         String?          @default("")
  musicUrl         String?          @default("")
  carruselImages   Json?            @default("[]") 

  // --- Datos Principales ---
  eventName        String           @default("")
  eventDate        String           @default("")
  eventTime        String           @default("")
  confirmDate      String           @default("") // Fecha límite para RSVP
  confirmPhone     String?          @default("") // Nuevo: Para el Plan Classic (WhatsApp)
  
  // --- Ubicaciones ---
  venueName        String           @default("")
  venueAddress     String           @default("")
  mapLink          String           @default("")
  
  churchName       String?          @default("")
  churchAddress    String?          @default("")
  churchMapLink    String?          @default("")
  churchDate       String?          @default("") 
  churchTime       String?          @default("") 

  // --- Detalles ---
  dressCode        String?          @default("")
  dressDescription String?          @default("")

  // --- Regalos / Datos Bancarios ---
  cbu              String?          @default("")
  alias            String?          @default("")
  bankName         String?          @default("")
  holderName       String?          @default("")

  // --- Relaciones Dinámicas ---
  itinerary        ItineraryItem[]
  witnesses        Witness[]

  updatedAt        DateTime         @updatedAt
  @@map("event_config")
}

// 5. ITINERARIO
model ItineraryItem {
  id            String      @id @default(cuid())
  time          String      
  title         String      
  description   String?     
  icon          String      @default("Heart")
  order         Int         
  
  eventConfigId String
  eventConfig   EventConfig @relation(fields: [eventConfigId], references: [id], onDelete: Cascade)

  @@map("itinerary_items")
}

// 6. TESTIGOS / PADRINOS
model Witness {
  id            String      @id @default(cuid())
  nombre        String
  rol           String      
  imageUrl      String?     
  
  eventConfigId String
  eventConfig   EventConfig @relation(fields: [eventConfigId], references: [id], onDelete: Cascade)

  @@map("witnesses")
}

// 7. LOS INVITADOS (Reforzado para Deluxe)
model Guest {
  id                String   @id @default(cuid())
  nombre            String   
  cupos             Int      @default(1)
  confirmados       Int      @default(0)
  codigo            String   @unique  
  status            String   @default("PENDING") 
  dietary           String?  
  message           String?  
  
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  mesa              String?  @default("A Designar")
  asistio           Boolean  @default(false) // Esto es para el Check-in QR del Deluxe
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("guests")
}

// 8. SUGERENCIAS DE MÚSICA
model SongSuggestion {
  id          String   @id @default(cuid())
  tema1       String?
  tema2       String?
  tema3       String?
  guestName   String?  
  
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  
  @@map("song_suggestions")
}