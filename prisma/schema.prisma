generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 1. EL CLIENTE (Dueño de la invitación)
model User {
  id              String   @id @default(cuid())
  nombre          String
  email           String   @unique
  password        String
  role            String   @default("USER") // "ADMIN" o "USER"
  
  // Datos para la URL y Diseño
  slug            String   @unique // Ej: "boda-mario-y-clara"
  templateId      String   @default("")

  // Relaciones
  eventConfig     EventConfig? 
  guests          Guest[]
  songSuggestions SongSuggestion[]
  orders          Order[] // <-- RELACIÓN CON LAS ÓRDENES DE PAGO

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("users")
}

// 2. MODELO DE ÓRDENES Y PAGOS
enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
}

model Order {
  id                String        @id @default(cuid())
  userId            String?       
  user              User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  planName          String        // CLASSIC, PREMIUM, DELUXE
  amount            Float
  status            PaymentStatus @default(PENDING)
  
  mpPreferenceId    String?       @unique 
  mpPaymentId       String?       @unique 
  
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@map("orders")
}

// 3. CONFIGURACIÓN DEL EVENTO
model EventConfig {
  id               String          @id @default(cuid())
  userId           String          @unique
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  // --- Multimedia ---
  heroImage        String?         @default("")
  videoUrl         String?         @default("")
  musicUrl         String?         @default("")
  carruselImages   Json?           @default("[]") 

  // --- Datos Principales ---
  eventName        String          @default("")
  eventDate        String          @default("")
  eventTime        String          @default("")
  
  // --- Ubicaciones ---
  venueName        String          @default("")
  venueAddress     String          @default("")
  mapLink          String          @default("")
  
  churchName       String?         @default("")
  churchAddress    String?         @default("")
  churchMapLink    String?         @default("")
  churchDate       String?         @default("") 
  churchTime       String?         @default("") 

  // --- Detalles ---
  dressCode        String?         @default("")
  dressDescription String?         @default("")

  // --- Regalos / Datos Bancarios ---
  cbu              String?         @default("")
  alias            String?         @default("")
  bankName         String?         @default("")
  holderName       String?         @default("")

  // --- Relaciones Dinámicas ---
  itinerary        ItineraryItem[]
  witnesses        Witness[]

  updatedAt        DateTime        @updatedAt
  @@map("event_config")
}

// 4. ITINERARIO
model ItineraryItem {
  id            String      @id @default(cuid())
  time          String      
  title         String      
  description   String?     
  icon          String      @default("Heart")
  order         Int         
  
  eventConfigId String
  eventConfig   EventConfig @relation(fields: [eventConfigId], references: [id], onDelete: Cascade)

  @@map("itinerary_items")
}

// 5. TESTIGOS / PADRINOS
model Witness {
  id            String      @id @default(cuid())
  nombre        String
  rol           String      
  imageUrl      String?     
  
  eventConfigId String
  eventConfig   EventConfig @relation(fields: [eventConfigId], references: [id], onDelete: Cascade)

  @@map("witnesses")
}

// 6. LOS INVITADOS
model Guest {
  id                String   @id @default(cuid())
  nombre            String   
  cupos             Int      @default(1)
  confirmados       Int      @default(0)
  codigo            String   @unique  
  status            String   @default("PENDING") 
  dietary           String?  
  message           String?  
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mesa              String?  @default("A Designar")
  asistio           Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("guests")
}

// 7. SUGERENCIAS DE MÚSICA
model SongSuggestion {
  id          String   @id @default(cuid())
  tema1       String?
  tema2       String?
  tema3       String?
  guestName   String?  
  
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  
  @@map("song_suggestions")
}