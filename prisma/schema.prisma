generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 1. EL CLIENTE (Dueño de la invitación)
model User {
  id              String   @id @default(cuid())
  nombre          String
  email           String   @unique
  password        String
  role            String   @default("USER") // "ADMIN" o "USER"
  
  // Datos para la URL y Diseño
  slug            String   @unique // Ej: "boda-mario-y-clara"
  templateId      String   @default("")

  // Relaciones
  eventConfig     EventConfig? 
  guests          Guest[]
  songSuggestions SongSuggestion[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("users")
}

// 2. CONFIGURACIÓN DEL EVENTO (Lo que el cliente edita en su panel)
model EventConfig {
  id               String          @id @default(cuid())
  userId           String          @unique
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  // --- Multimedia ---
  heroImage        String?         @default("")
  videoUrl         String?         @default("")
  musicUrl         String?         @default("")
  // Usamos Json para manejar los arrays de Cloudinary nativamente
  carruselImages   Json?           @default("[]") 

  // --- Datos Principales ---
  eventName        String          @default("")
  eventDate        String          @default("")
  eventTime        String          @default("")
  
  // --- Ubicaciones ---
  // Salón / Fiesta
  venueName        String          @default("")
  venueAddress     String          @default("")
  mapLink          String          @default("")
  
  // Iglesia / Ceremonia (Opcionales para Bodas)
  churchName       String?         @default("")
  churchAddress    String?         @default("")
  churchMapLink    String?         @default("")
  churchDate       String?         @default("") 
  churchTime       String?         @default("") 

  // --- Detalles ---
  dressCode        String?         @default("")
  dressDescription String?         @default("")

  // --- Regalos / Datos Bancarios ---
  cbu              String?         @default("")
  alias            String?         @default("")
  bankName         String?         @default("")
  holderName       String?         @default("")

  // --- Relaciones Dinámicas ---
  itinerary        ItineraryItem[]
  witnesses        Witness[]

  updatedAt        DateTime        @updatedAt
  @@map("event_config")
}

// 3. ITINERARIO (Cronograma del evento)
model ItineraryItem {
  id            String      @id @default(cuid())
  time          String      // Ej: "21:00hs"
  title         String      // Ej: "Recepción"
  description   String?     
  icon          String      @default("Heart") // Nombre del icono de Lucide/React Icons
  order         Int         // Para ordenar manualmente 1, 2, 3...
  
  eventConfigId String
  eventConfig   EventConfig @relation(fields: [eventConfigId], references: [id], onDelete: Cascade)

  @@map("itinerary_items")
}

// 4. TESTIGOS / PADRINOS
model Witness {
  id            String      @id @default(cuid())
  nombre        String
  rol           String      // Ej: "Testigo de la Novia"
  imageUrl      String?     
  
  eventConfigId String
  eventConfig   EventConfig @relation(fields: [eventConfigId], references: [id], onDelete: Cascade)

  @@map("witnesses")
}

// 5. LOS INVITADOS (Gestión de lista y confirmaciones)
model Guest {
  id               String   @id @default(cuid())
  nombre           String   // Ej: "Familia Ariel" o "Mario Barrera"
  cupos            Int      @default(1) // Cupos totales otorgados
  confirmados      Int      @default(0) // Cupos que realmente confirmaron
  codigo           String   @unique     // Código de acceso único
  status           String   @default("PENDING") // PENDING, CONFIRMED, CANCELLED
  dietary          String?  // Info sobre alergias, vegetariano, etc.
  message     String?  // <--- AGREGAR ESTO SI NO ESTÁ
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
mesa             String?  @default("A Designar")
asistio         Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("guests")
}

// 6. SUGERENCIAS DE MÚSICA (Interacción de invitados)
model SongSuggestion {
  id          String   @id @default(cuid())
  tema1       String?
  tema2       String?
  tema3       String?
  guestName   String?  // Quién sugirió la canción
  
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  
  @@map("song_suggestions")
}